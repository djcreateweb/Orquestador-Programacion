# Copia este archivo a .env y rellena los valores.
# El .env NO se sube a git (ya esta en .gitignore).

# ----- Henrik Dev API (datos Valorant) -----
# Solicita una en https://api.henrikdev.xyz/dashboard/
HENRIK_API_KEY=HDEV-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ----- Google OAuth 2.0 -----
# https://console.cloud.google.com/apis/credentials
#   1. Crea proyecto, configura OAuth consent screen (External).
#   2. Credentials -> Create Credentials -> OAuth client ID -> Web application.
#   3. Authorized redirect URI: exactamente el valor de GOOGLE_REDIRECT_URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/Claude%20Orquestador/agentes-claude/proyectos/_plantilla/ValoSense/index.php?controlador=usuario&action=google_callback
