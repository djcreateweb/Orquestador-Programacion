# Giant Barber Studio — Apache (producción).
# Requiere mod_rewrite, mod_headers, mod_expires, mod_deflate.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS obligatorio
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www -> apex
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # URL corta para reseñas de Google (QR y tarjetas)
  RewriteRule ^resena/?$ https://g.page/r/Cf4gq3v3Ng7dEBM/review [R=301,L]
  RewriteRule ^resenas/?$ https://g.page/r/Cf4gq3v3Ng7dEBM/review [R=301,L]
  RewriteRule ^review/?$ https://g.page/r/Cf4gq3v3Ng7dEBM/review [R=301,L]

  # Compatibilidad rutas antiguas
  RewriteRule ^img/(.*)$ /Imagenes/$1 [R=301,L]
  RewriteRule ^imagenes%20giant/(.*)$ /Imagenes/Hero/$1 [R=301,L]
  RewriteRule ^sitemap\.xml$ /Data/sitemap.xml [R=301,L]
  RewriteRule ^site\.webmanifest$ /Data/site.webmanifest [R=301,L]
</IfModule>

Options -Indexes

<IfModule mod_authz_core.c>
  # Block sensitive file extensions
  <FilesMatch "(?i)\.(env|log|bak|sql|ini|sh|conf|config|dist|orig|swp|swo|DS_Store)$">
    Require all denied
  </FilesMatch>
  # Block sensitive filenames and directories
  <FilesMatch "(?i)^(\.git|\.gitignore|\.gitattributes|package\.json|package-lock\.json|composer\.json|composer\.lock|yarn\.lock|webpack\.config\.js|vite\.config\.js|\.editorconfig|\.eslintrc|\.prettierrc|CHANGELOG|README|LICENSE)">
    Require all denied
  </FilesMatch>
  # Block access to hidden files/directories (starting with dot)
  <FilesMatch "^\.">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript \
    application/javascript application/json application/xml application/manifest+json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresDefault "access plus 2 days"
</IfModule>

<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://images.unsplash.com; connect-src 'self'; frame-src https://www.google.com https://maps.google.com https://maps.googleapis.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), interest-cohort=(), fullscreen=(self), browsing-topics=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  # Cache-Control for HTML: prevent stale security-sensitive pages being cached
  <FilesMatch "\.(html|htm)$">
    Header always set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Cache-Control for static assets — 1 year (immutable for versioned assets)
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|ico|svg)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache-Control for CSS and JS — 1 month (update filenames when content changes)
  <FilesMatch "\.(css|js)$">
    Header always set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Cache-Control for fonts — 1 year
  <FilesMatch "\.(woff|woff2|ttf|eot|otf)$">
    Header always set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache-Control for web manifest — 1 week
  <FilesMatch "\.(webmanifest|json)$">
    Header always set Cache-Control "public, max-age=604800"
  </FilesMatch>

  Header unset X-Powered-By
  Header unset Server
</IfModule>
